# AI TO AI HOLDING — Environment Variables
# คัดลอกไฟล์นี้เป็น .env แล้วแก้ค่าให้ถูกต้อง
# NEVER commit .env ขึ้น GitHub

# ── Mode ──────────────────────────────────────────────────────
# true  = Mock Mode (ไม่เสีย Claude API credit — ใช้ตอน test)
# false = Real Mode (เรียก Claude API จริง — ใช้ตอน production)
MOCK_MODE=true

# ── API Keys (ลูกค้าต้องส่ง header นี้) ──────────────────────
# สร้างด้วย: python3 -c "import secrets; print(secrets.token_hex(32))"
# คั่นด้วย comma ถ้ามีหลาย key
API_KEYS=your_secret_api_key_here

# ── Claude API (ต้องการเมื่อ MOCK_MODE=false) ────────────────
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxx

# ── Database ──────────────────────────────────────────────────
DB_PATH=

# ── Security ──────────────────────────────────────────────────
# IP ของ Chairman สำหรับ endpoint ที่ sensitive
# หา IP ได้ที่ https://api.ipify.org
CHAIRMAN_ALLOWED_IPS=127.0.0.1,::1

# ── CORS ──────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ── Pricing ───────────────────────────────────────────────────
PRICE_PER_ITEM=1.50
ENERGY_COST_PER_CALL=0.02

# ── Stripe (ใส่เมื่อสร้าง Billing System — Step 2) ───────────
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxx
